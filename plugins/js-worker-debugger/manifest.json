{
  "name": "plugin-debugger",
  "display_name": "Plugin Debugger",
  "description": "Unified JS Worker debugger that demonstrates full official hook coverage, frontend bootstrap, payload patch/block behavior, native host data helpers, market/template bridges, storage, network, sandbox limits, plugin filesystem access, secret injection, webhook inspection, self-test diagnostics, and workspace reports.",
  "type": "custom",
  "runtime": "js_worker",
  "entry": "index.js",
  "version": "2.5.0",
  "manifest_version": "1.0.0",
  "protocol_version": "1.0.0",
  "min_host_protocol_version": "1.0.0",
  "max_host_protocol_version": "1.0.0",
  "activate": true,
  "auto_start": true,
  "config": {
    "enable_frontend": true,
    "enable_auth": true,
    "enable_platform": true,
    "enable_commerce": true,
    "enable_catalog": true,
    "enable_support": true,
    "enable_content": true,
    "enable_settings": true,
    "emit_frontend_extensions": false,
    "emit_payload_marker": true,
    "persist_events": true,
    "max_events": 40,
    "demo_block_before_hooks": false,
    "block_keyword": "debug-block",
    "slot_notice_mode": "compact"
  },
  "config_schema": {
    "title": "Plugin Debugger Config",
    "description": "Visual defaults for the unified debugger. Administrators can still override these values after upload.",
    "fields": [
      {
        "key": "enable_frontend",
        "label": "Enable Frontend Hooks",
        "description": "Keep frontend.slot.render diagnostics active.",
        "type": "boolean",
        "default": true
      },
      {
        "key": "enable_auth",
        "label": "Enable Auth & User Hooks",
        "description": "Capture auth, account binding, password, preferences, and admin user management hooks.",
        "type": "boolean",
        "default": true
      },
      {
        "key": "enable_platform",
        "label": "Enable Platform Hooks",
        "description": "Capture plugin lifecycle, package upload, secret, API key, upload, and log hooks.",
        "type": "boolean",
        "default": true
      },
      {
        "key": "enable_commerce",
        "label": "Enable Commerce Hooks",
        "description": "Capture cart, order, payment, promo, and serial hooks.",
        "type": "boolean",
        "default": true
      },
      {
        "key": "enable_catalog",
        "label": "Enable Catalog Hooks",
        "description": "Capture product, inventory, and virtual inventory hooks.",
        "type": "boolean",
        "default": true
      },
      {
        "key": "enable_support",
        "label": "Enable Support Hooks",
        "description": "Capture ticket lifecycle hooks.",
        "type": "boolean",
        "default": true
      },
      {
        "key": "enable_content",
        "label": "Enable Content Hooks",
        "description": "Capture announcement, knowledge, marketing, email, and SMS hooks.",
        "type": "boolean",
        "default": true
      },
      {
        "key": "enable_settings",
        "label": "Enable Settings Hooks",
        "description": "Capture settings, landing page, email template, and template package hooks.",
        "type": "boolean",
        "default": true
      },
      {
        "key": "emit_frontend_extensions",
        "label": "Emit Frontend Extensions",
        "description": "Inject diagnostic cards into frontend slots.",
        "type": "boolean",
        "default": false
      },
      {
        "key": "emit_payload_marker",
        "label": "Emit Payload Marker",
        "description": "Attach plugin_debugger metadata to non-before hook payloads.",
        "type": "boolean",
        "default": true
      },
      {
        "key": "persist_events",
        "label": "Persist Hook Events",
        "description": "Store recent hook events in Plugin.storage.",
        "type": "boolean",
        "default": true
      },
      {
        "key": "max_events",
        "label": "Max Events",
        "description": "Retention count for the recent event log.",
        "type": "number",
        "default": 40
      },
      {
        "key": "demo_block_before_hooks",
        "label": "Enable Blocking Demo",
        "description": "Block .before hooks when payload contains the keyword below.",
        "type": "boolean",
        "default": false
      },
      {
        "key": "block_keyword",
        "label": "Block Keyword",
        "description": "Keyword used by the blocking demo.",
        "type": "string",
        "default": "debug-block"
      },
      {
        "key": "slot_notice_mode",
        "label": "Slot Notice Mode",
        "description": "Compact renders a short slot card; verbose renders a fuller message.",
        "type": "select",
        "default": "compact",
        "options": [
          {
            "label": "Compact",
            "value": "compact"
          },
          {
            "label": "Verbose",
            "value": "verbose"
          }
        ]
      }
    ]
  },
  "secret_schema": {
    "title": "Debugger Secret Schema",
    "description": "Optional sample secrets used to verify Plugin.secret runtime injection without exposing raw values in the debugger UI.",
    "fields": [
      {
        "key": "debugger_token",
        "label": "Debugger Token",
        "description": "Sample secret key used by the debugger to confirm secret bridge wiring and host secret injection.",
        "type": "secret",
        "default": ""
      }
    ]
  },
  "permissions": [
    {
      "key": "api.execute",
      "reason": "Allow plugin pages to call their own execute API from visual forms and HTML bridge demos."
    },
    {
      "key": "frontend.extensions",
      "reason": "Register debugger routes and inject diagnostic frontend cards across host slots."
    },
    {
      "key": "frontend.html_trusted",
      "reason": "Enable trusted HTML diagnostics so the debugger can verify trusted/sanitized page behavior when administrators explicitly grant it."
    },
    {
      "key": "hook.block",
      "reason": "Demonstrate hook blocking behavior for before-phase workflows."
    },
    {
      "key": "hook.execute",
      "reason": "Run inside the hook pipeline and capture live payload snapshots."
    },
    {
      "key": "hook.payload_patch",
      "reason": "Demonstrate payload patch behavior and observe host patch whitelist enforcement."
    },
